# Alpaca API Credentials
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets

# Google Gemini API Credentials
GEMINI_API_KEY=

# Z.ai API Credentials
ZAI_API_KEY=

# --- Risk Management & Execution Controls ---
# Maximum number of trades allowed per day (Prevents overtrading/bugs)
MAX_TRADES_PER_DAY=10

# Maximum percentage of the total portfolio to be invested (e.g. 0.80 = 80%)
MAX_PORTFOLIO_EXPOSURE_PCT=0.85

# Minimum cash reserve to maintain for emergencies (e.g. 0.15 = 15%)
MIN_CASH_RESERVE_PCT=0.15

# Maximum size for a single position relative to the account (e.g. 0.10 = 10%)
MAX_POSITION_SIZE_PCT=0.10

# Minimum confidence score from agents to execute a trade (0.0 to 1.0)
MIN_CONFIDENCE_SCORE=0.75

# Daily account-wide drawdown limit (e.g. 0.02 = 2% loss in one day shuts down system)
DAILY_DRAWDOWN_LIMIT_PCT=0.03
