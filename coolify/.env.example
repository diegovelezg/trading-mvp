# ===========================
# COOLIFY DEPLOYMENT CONFIG
# ===========================

# ----- Alpaca Trading (Paper Trading) -----
ALPACA_PAPER_API_KEY=YOUR_ALPACA_PAPER_API_KEY
PAPER_API_SECRET=your_secret_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets/v2

# ----- Alpaca Data API -----
ALPACA_DATA_API_KEY=YOUR_ALPACA_DATA_API_KEY
DATA_API_SECRET=your_data_secret_here
ALPACA_DATA_BASE_URL=https://api.alpaca.markets

# ----- Gemini AI -----
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_MODEL_01=gemini-2.0-flash-exp
GEMINI_API_MODEL_02=gemini-2.0-flash-exp
GEMINI_API_MODEL_03=gemini-3.1-pro-preview
GEMINI_API_MODEL_04=gemini-3.1-pro-preview
GEMINI_API_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_EMBEDDING_SIZE=768

# ----- Z.ai AI (Alternative) -----
ZAI_API_MODEL_01=glm-5.1
ZAI_API_KEY=your_zai_key_here

# ----- SerpAPI (News) -----
SERPAPI_API_KEY=your_serpapi_key_here

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
DATABASE_URL=postgresql://postgres.dev_tenant:password@host:6544/postgres

# ----- System Config -----
AUTOPILOT_MODE=on

# ----- Risk Management -----
# Maximum number of trades per day
MAX_TRADES_PER_DAY=10

# Maximum portfolio exposure (0.85 = 85%)
MAX_PORTFOLIO_EXPOSURE_PCT=0.85

# Minimum cash reserve (0.15 = 15%)
MIN_CASH_RESERVE_PCT=0.15

# Maximum single position size (0.10 = 10%)
MAX_POSITION_SIZE_PCT=0.10

# Minimum confidence score to execute (0.0 to 1.0)
MIN_CONFIDENCE_SCORE=0.75

# Daily drawdown limit (0.03 = 3% loss shuts down system)
DAILY_DRAWDOWN_LIMIT_PCT=0.03